# DATABASE
# Koda uses SQLite by default for easy setup.
DATABASE_URL="file:./dev.db"

# AUTHENTICATION (Auth.js / NextAuth v5)
# Generate a secure 32-character string: npx auth secret
AUTH_SECRET="your_secure_auth_secret_here"
AUTH_URL="http://localhost:3000"

# AI PROVIDERS (For automated support system)
# Available options: gemini, openrouter, claude, grok
ACTIVE_AI_PROVIDER="gemini" 

# Fill in the keys for the providers you intend to use
GEMINI_API_KEY="your_gemini_api_key_here"
OPENROUTER_API_KEY=""
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# PAYMENT GATEWAYS
# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# SITE SETTINGS
NEXT_PUBLIC_STORE_NAME="Koda Store"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
